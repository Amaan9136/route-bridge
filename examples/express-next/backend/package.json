{
  "name": "example-express-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "generate": "route-bridge generate --manifest ./route-bridge.manifest.json --output ../frontend/src/generated",
    "dev:generate": "route-bridge generate --manifest ./route-bridge.manifest.json --output ../frontend/src/generated --watch"
  },
  "dependencies": {
    "@route-bridge/express": "workspace:*",
    "@route-bridge/config": "workspace:*",
    "@route-bridge/logger": "workspace:*",
    "@route-bridge/generator": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.18.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
