{
  "name": "route-bridge-monorepo",
  "private": true,
  "version": "0.0.1",
  "description": "route-bridge monorepo - define backend routes once, call them from the frontend as typed functions",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "generate": "pnpm --filter @route-bridge/generator generate",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean"
  },
  "workspaces": [
    "packages/*",
    "examples/express-next/backend",
    "examples/express-next/frontend",
    "examples/flask-next/frontend"
  ],
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20.12.7"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
