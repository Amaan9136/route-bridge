{
  "name": "route-bridge",
  "private": false,
  "version": "0.0.4",
  "description": "route-bridge lets you define backend APIs once and automatically use them in frontend apps as simple function calls. It generates a typed client from a shared contract, removing fetch boilerplate and supporting Express, Flask, Next.js, and Node.js with clean DX.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Amaan9136/route-bridge.git"
  },
  "homepage": "https://github.com/Amaan9136/route-bridge#readme",
  "bugs": {
    "url": "https://github.com/Amaan9136/route-bridge/issues"
  },
  "keywords": [
    "api",
    "codegen",
    "typescript",
    "express",
    "flask",
    "nextjs",
    "fetch",
    "client",
    "contract",
    "route-bridge"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/**' build",
    "build:examples": "pnpm -r --filter './examples/**' build",
    "dev": "pnpm -r --parallel --filter './packages/**' dev",
    "test": "pnpm -r test",
    "generate": "pnpm --filter @route-bridge/generator generate",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "release": "node scripts/release.js",
    "versions": "node scripts/versions.js"
  },
  "workspaces": [
    "packages/*",
    "examples/express-next/backend",
    "examples/express-next/frontend",
    "examples/flask-next/frontend"
  ],
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20.12.7"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}