{
  "name": "@route-bridge/generator",
  "version": "0.0.6",
  "description": "Code generator: reads the route-bridge manifest and generates a typed TypeScript client",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Amaan9136/route-bridge.git",
    "directory": "packages/generator"
  },
  "homepage": "https://github.com/Amaan9136/route-bridge/tree/main/packages/generator#readme",
  "bugs": {
    "url": "https://github.com/Amaan9136/route-bridge/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "route-bridge": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "generate": "node dist/cli.js generate",
    "test": "npm run build && node dist/index.test.js"
  },
  "dependencies": {
    "@route-bridge/core": "0.0.2",
    "@route-bridge/config": "0.0.2",
    "@route-bridge/logger": "0.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "typescript": "^5.4.5"
  },
  "publishConfig": {
    "access": "public"
  }
}